# Environment Configuration
ENV_NAME=development
PORT=3001
LOCAL=true

# Application URL
URL=http://localhost:3001

# Phone number encryption (AES-256-GCM with key rotation)
# Generate each key with: openssl rand -hex 32
# To rotate: add PHONE_ENC_KEY_{n+1}, bump PHONE_ENC_KEY_VERSION — old records still decrypt.
PHONE_ENC_KEY_VERSION=1
PHONE_ENC_KEY_1=

# Google Sign-In (Android)
# From Google Cloud Console → OAuth 2.0 Client IDs → Android client ID
GOOGLE_CLIENT_ID=
