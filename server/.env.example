# Environment Configuration
ENV_NAME=development
PORT=3001
LOCAL=true

# Database
MONGO_HOST=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_PORT=27017

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Secrets
APP_SECRET=your-secret-key-change-this
APP_SECRET_REFRESH=your-refresh-secret-key-change-this

# AWS Credentials
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_BUCKET_NAME=winky-chat
AWS_REGION=us-east-1
AWS_API_ENDPOINT=https://winky.com/

# Twilio Configuration
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_API_KEY=your-api-key
TWILIO_API_KEY_SECRET=your-api-key-secret
TWILIO_IOS_PUSH_CREDENTIAL_SID=your-ios-credential-sid
TWILIO_ANDROID_PUSH_CREDENTIAL_SID=your-android-credential-sid
TWILIO_APP_SID=your-app-sid
TWILIO_NOTIFICATION_SERVICE_SID=your-notification-service-sid

# Apple Push Notifications
IOS_BUNDLE=com.app.winky
IOS_KEY_TOKEN=2XCWJRBL6T
IOS_TEAM_ID=EKH9RC2775

# Google Cloud Messaging
GCM_SERVER_ID=your-gcm-server-id

# Application URL
URL=http://localhost:3001
